    "        \n",
    "        # BORRAR DATOS VIEJOS (Elimina los libros de Sapiens, etc.)\n",
    "        coleccion.delete_many({}) \n",
    "        \n",
    "        # INSERTAR NUEVOS DATOS\n",
    "        coleccion.insert_many(datos_finales)\n",
